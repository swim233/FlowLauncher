<ResourceDictionary xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="FlowAccent">#66CCFF</Color>
    <Color x:Key="FlowTopBarForeground">#FFF</Color>

    <!-- Theme Variants -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <Color x:Key="FlowTextPrimary">#111</Color>
            <Color x:Key="FlowTextSecondary">#444</Color>
            <Color x:Key="FlowBackground">#FFF</Color>
            <Color x:Key="FlowWindowBackground">#AEEE</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="FlowTextPrimary">#eee</Color>
            <Color x:Key="FlowTextSecondary">#889</Color>
            <Color x:Key="FlowBackground">#222</Color>
            <Color x:Key="FlowWindowBackground">#E000</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
