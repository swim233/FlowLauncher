<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:v="clr-namespace:FlowLauncher.Views"
        xmlns:c="clr-namespace:FlowLauncher.Controls"
        xmlns:p="clr-namespace:FlowLauncher.Platforms"
        x:Class="FlowLauncher.Platforms.WindowsWindow"
        Icon="/Assets/logo.ico" Title="Flow Launcher"
        MinWidth="900" MinHeight="540"
        Width="900" Height="540"
        DataContext="{Binding RelativeSource={RelativeSource Self}}"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Background="{x:Null}">
    <Grid x:Name="BackgroundPanel" Margin="8" RenderTransform="scale(0.7)" Opacity="0">
        <Grid.Transitions>
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform"
                        Duration="0:0:1" Easing="{StaticResource SpringEasing}"/>
                <DoubleTransition Property="Opacity" Duration="0:0:.5"/>
            </Transitions>
        </Grid.Transitions>
        <Grid.Resources>
            <CornerRadius x:Key="CornerRadius">8</CornerRadius>
        </Grid.Resources>
        <Border CornerRadius="{DynamicResource CornerRadius}"
                Background="{DynamicResource FlowWindowBackground}"
                BoxShadow="0 0 12 -2 Black"/>
        <Border CornerRadius="{DynamicResource CornerRadius}"
                ClipToBounds="True">
            <Grid>
                <v:RootLayout ParentWindow="{Binding RelativeSource={RelativeSource AncestorType=p:BaseWindow}}"
                        DataContext="{Binding RootLayout, RelativeSource={RelativeSource AncestorType=p:BaseWindow}}"/>
                <Grid Height="{StaticResource TopBarHeight}" VerticalAlignment="Top"
                        ColumnDefinitions="10,Auto,*,Auto,Auto,10" ColumnSpacing="5">
                    <Grid.Styles>
                        <Style Selector="Grid.Nav">
                            <Setter Property="Transitions">
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:.1"/>
                                </Transitions>
                            </Setter>
                        </Style>
                    </Grid.Styles>
                    <Grid Grid.Column="1" Classes="Nav" x:Name="BackPanel" Opacity="0"
                            ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10">
                        <Grid.RenderTransform>
                            <TranslateTransform X="-40" Y="0">
                                <TranslateTransform.Transitions><Transitions>
                                    <DoubleTransition Property="X" Duration="0:0:.4"
                                            Easing="{StaticResource SpringEasing}"/>
                                </Transitions></TranslateTransform.Transitions>
                            </TranslateTransform>
                        </Grid.RenderTransform>
                        <!-- ReSharper disable once Xaml.PossibleNullReferenceException -->
                        <c:FlowRadioButton Grid.Column="0" Classes="TopBar IconOnly"
                                Icon="{StaticResource IconArrowLeft}" Click="BackButton_OnClick"
                                IsEnabled="{Binding RootLayout.HasLastPage}"
                                ToolTip.Tip="{Binding RootLayout.LastPage.Title}"/>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                Text="{Binding RootLayout.CurrentPage.Title}" FontSize="16"/>
                    </Grid>
                    <Grid Grid.Column="1" Classes="Nav" x:Name="TitlePanel" Opacity="1">
                        <Grid.RenderTransform>
                            <TranslateTransform X="0" Y="0">
                                <TranslateTransform.Transitions><Transitions>
                                    <DoubleTransition Property="X" Duration="0:0:.4"
                                            Easing="{StaticResource SpringEasing}"/>
                                </Transitions></TranslateTransform.Transitions>
                            </TranslateTransform>
                        </Grid.RenderTransform>
                        <c:FlowRadioButton Classes="TopBar" Text="Flow Launcher"
                                IsChecked="True" Click="TitleButton_OnClick"
                                PressingForeground="Black" Background="#BFFF"
                                FontSize="14" FontWeight="Medium"
                                IsEnabled="{Binding !RootLayout.HasLastPage}"/>
                    </Grid>
                    <c:FlowRadioButton Grid.Column="3" Classes="TopBar IconOnly"
                            Click="ButtonMinimize_OnClick" Icon="{StaticResource IconMinimize}"/>
                    <c:FlowRadioButton Grid.Column="4" Classes="TopBar IconOnly"
                            Click="ButtonClose_OnClick" Icon="{StaticResource IconClose}"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
