<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FlowLauncher.App"
             xmlns:local="using:FlowLauncher"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary><ResourceDictionary.MergedDictionaries>
            <!-- Icons -->
            <MergeResourceInclude Source="Resources/Icons.axaml"/>
            <!-- Colors -->
            <MergeResourceInclude Source="Resources/Colors.axaml"/>
            <!-- Global Values -->
            <MergeResourceInclude Source="Resources/Values.axaml"/>
        </ResourceDictionary.MergedDictionaries></ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <!-- Default Theme -->
        <FluentTheme/>
        <!-- Template Control Styles -->
        <StyleInclude Source="Controls/ControlStyles.axaml"/>
        <!-- Custom Styles -->
        <StyleInclude Source="Resources/CustomStyles.axaml"/>
    </Application.Styles>

</Application>
