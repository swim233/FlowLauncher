<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FlowLauncher.ViewModels"
        xmlns:c="clr-namespace:FlowLauncher.Controls"
        xmlns:r="clr-namespace:FlowLauncher.Resources"
        xmlns:p="clr-namespace:FlowLauncher.Platforms"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="FlowLauncher.Views.MainPage"
        x:DataType="vm:MainPageViewModel">
    <Grid>
        <c:FlowRadioButton Text="Forward Test" HorizontalAlignment="Center" VerticalAlignment="Center"
                Command="{Binding RootLayout.ForwardCommand}" CommandParameter="tools"/>
    </Grid>
</UserControl>
