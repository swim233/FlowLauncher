<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FlowLauncher.ViewModels"
        xmlns:c="clr-namespace:FlowLauncher.Controls"
        xmlns:r="clr-namespace:FlowLauncher.Resources"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="540"
        x:Class="FlowLauncher.Views.RootLayout"
        x:DataType="vm:RootLayoutViewModel">
    <DockPanel>
        <!-- top bar -->
        <Grid DockPanel.Dock="Top" Height="{StaticResource TopBarHeight}"
                Background="{DynamicResource FlowAccent}" PointerPressed="TopBar_OnPointerPressed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10"
                    Opacity="{Binding !HasLastPage, Converter={x:Static c:Converters.BoolToOpacity}}">
                <StackPanel.Transitions>
                    <Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:.1"/>
                    </Transitions>
                </StackPanel.Transitions>
                <StackPanel.Styles>
                    <Style Selector="c|FlowRadioButton">
                        <Setter Property="IsChecked">
                            <MultiBinding Converter="{x:Static c:Converters.AllEqual}">
                                <Binding Path="CurrentPage.Id"/>
                                <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                            </MultiBinding>
                        </Setter>
                        <Setter Property="Command" Value="{Binding NavigateCommand}"/>
                        <Setter Property="CommandParameter" Value="{Binding Tag, RelativeSource={RelativeSource Self}}"/>
                    </Style>
                </StackPanel.Styles>
                <c:FlowRadioButton Classes="TopBar" Icon="{StaticResource IconPlay}"
                        Text="{x:Static r:Strings.PageTitleMain}" Tag="main"/>
                <c:FlowRadioButton Classes="TopBar" Icon="{StaticResource IconDownload}"
                        Text="{x:Static r:Strings.PageTitleInstall}" Tag="install"/>
                <c:FlowRadioButton Classes="TopBar" Icon="{StaticResource IconTools}"
                        Text="{x:Static r:Strings.PageTitleTools}" Tag="tools"/>
                <c:FlowRadioButton Classes="TopBar" Icon="{StaticResource IconSettings}"
                        Text="{x:Static r:Strings.PageTitleSettings}" Tag="settings"/>
            </StackPanel>
            <Border Background="Transparent" IsVisible="{Binding HasLastPage}"/>
        </Grid>
        <!-- main content -->
        <Grid>
            <Button Content="Forward" Command="{Binding ForwardCommand}" CommandParameter="tools"/>
        </Grid>
    </DockPanel>
</UserControl>
