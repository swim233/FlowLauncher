<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="clr-namespace:FlowLauncher.Controls"
        xmlns:p="clr-namespace:FlowLauncher.Components.Platforms"
        xmlns:r="clr-namespace:FlowLauncher.Resources"
        xmlns:ui="clr-namespace:FlowLauncher.Components.UI"
        x:Class="FlowLauncher.Components.Platforms.WindowsWindow"
        Icon="/Assets/logo.ico" Title="{x:Static r:Strings.AppTitle}"
        MinWidth="900" MinHeight="540"
        Width="900" Height="540"
        DataContext="{Binding RelativeSource={RelativeSource Self}}"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Background="{x:Null}">
    <Grid x:Name="RootPanel" Margin="{DynamicResource WindowMargin}"
            RenderTransform="scale(0.7)" Opacity="0">
        <Grid.Transitions>
            <Transitions>
                <TransformOperationsTransition Property="RenderTransform"
                        Duration="0:0:1" Easing="{StaticResource SpringEasing}"/>
                <DoubleTransition Property="Opacity" Duration="0:0:.5"/>
            </Transitions>
        </Grid.Transitions>
        <Border CornerRadius="{DynamicResource WindowCornerRadius}"
                IsVisible="{Binding !UseNativeWindowFrame}"
                BoxShadow="{StaticResource Shadow}"/>
        <Border CornerRadius="{DynamicResource WindowCornerRadius}"
                Background="{DynamicResource FlowWindowBackground}"
                ClipToBounds="True">
            <Grid>
                <ui:RootLayout ParentWindow="{Binding RelativeSource={RelativeSource AncestorType=p:BaseWindow}}"
                        DataContext="{Binding RootLayout, RelativeSource={RelativeSource AncestorType=p:BaseWindow}}"/>
                <Grid Height="{StaticResource TopBarHeight}" VerticalAlignment="Top"
                        ColumnDefinitions="10,Auto,*,Auto,10" ColumnSpacing="5">
                    <Grid.Styles>
                        <Style Selector="Grid.Nav">
                            <Setter Property="Transitions">
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:.1"/>
                                </Transitions>
                            </Setter>
                        </Style>
                    </Grid.Styles>
                    <Grid Grid.Column="1" Classes="Nav" x:Name="BackPanel" IsVisible="False"
                            ColumnDefinitions="Auto,Auto,*" ColumnSpacing="10"
                            Opacity="{Binding RootLayout.HasLastPage, Converter={x:Static c:Converters.BoolToOpacity}}">
                        <Grid.RenderTransform>
                            <TranslateTransform X="-40" Y="0">
                                <TranslateTransform.Transitions><Transitions>
                                    <DoubleTransition Property="X" Duration="0:0:.4"
                                            Easing="{StaticResource SpringEasing}"/>
                                </Transitions></TranslateTransform.Transitions>
                            </TranslateTransform>
                        </Grid.RenderTransform>
                        <!-- ReSharper disable once Xaml.PossibleNullReferenceException -->
                        <c:FlowRadioButton Grid.Column="0" Classes="TopBar IconOnly"
                                Icon="{StaticResource IconArrowLeft}" Click="BackButton_OnClick"
                                IsEnabled="{Binding RootLayout.HasLastPage}"
                                ToolTip.Tip="{Binding RootLayout.LastPage.Title}"/>
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="16"
                                Foreground="{DynamicResource FlowTopBarForeground}"
                                Text="{Binding RootLayout.CurrentPagePreview.Title}"/>
                    </Grid>
                    <Grid Grid.Column="1" Classes="Nav" x:Name="TitlePanel" IsVisible="True"
                            Opacity="{Binding !RootLayout.HasLastPage, Converter={x:Static c:Converters.BoolToOpacity}}">
                        <Grid.RenderTransform>
                            <TranslateTransform X="0" Y="0">
                                <TranslateTransform.Transitions><Transitions>
                                    <DoubleTransition Property="X" Duration="0:0:.4"
                                            Easing="{StaticResource SpringEasing}"/>
                                </Transitions></TranslateTransform.Transitions>
                            </TranslateTransform>
                        </Grid.RenderTransform>
                        <c:FlowRadioButton Classes="TopBar" Text="Flow Launcher"
                                IsChecked="True" IsEnabled="False"
                                PressingForeground="Black" Background="#BFFF"
                                FontSize="14" FontWeight="Medium"/>
                    </Grid>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="5">
                        <c:FlowRadioButton Classes="TopBar IconOnly" Click="ButtonTestNativeWindow_OnClick" Icon="{StaticResource IconTools}"/>
                        <c:FlowRadioButton Classes="TopBar IconOnly" Click="ButtonMinimize_OnClick" Icon="{StaticResource IconMinimize}"/>
                        <c:FlowRadioButton Classes="TopBar IconOnly" Click="ButtonClose_OnClick" Icon="{StaticResource IconClose}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
